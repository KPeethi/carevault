# Gmail email notifications.
# Create a Gmail App Password and paste it here. Your normal Gmail password will not work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=kulkarni.preethi99@gmail.com
SMTP_PASS=GMAIL_APP_PASSWORD_HERE
