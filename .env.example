# SQL Server storage.
DB_SERVER=(local)\MSSQL2025
DB_DATABASE=CareVault
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED_CONNECTION=yes

# Optional: use this full connection string instead of the DB_* keys above.
# CAREVAULT_MSSQL_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=(local)\MSSQL2025;Database=CareVault;Trusted_Connection=yes;
MSSQL_SUBMISSIONS_TABLE=CareVaultSubmissions
MSSQL_REQUESTS_TABLE=CareVaultRequests
MSSQL_REQUIRE_SUCCESS=false
